.coupon-screen {
  padding-bottom: 40rpx;
}

.coupon-summary-card__label {
  font-size: 22rpx;
  color: #666666;
}

.coupon-summary-card__value {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
}

.coupon-summary-card__desc {
  margin-top: 12rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #666666;
}

.coupon-summary-card__actions {
  margin-top: 18rpx;
}

.coupon-summary-card__ghost {
  display: inline-flex;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  color: #666666;
  font-size: 22rpx;
}

.coupon-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 16rpx 24rpx 0;
}

.coupon-tabs__item {
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  background: #ffffff;
  color: #666666;
  font-size: 24rpx;
  border: 1rpx solid #eeeeee;
}

.coupon-tabs__item--active {
  background: #fff1f0;
  border-color: #ffd8d3;
  color: #ff4a43;
  font-weight: 600;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.empty-card__desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.coupon-card {
  display: grid;
  grid-template-columns: 130rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
}

.coupon-card--disabled {
  opacity: 0.72;
}

.coupon-card__amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff4a43;
  text-align: center;
}

.coupon-card__title {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #222222;
}

.coupon-card__desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #666666;
}

.coupon-card__meta,
.coupon-card__reason {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
}

.coupon-card__meta {
  color: #999999;
}

.coupon-card__reason {
  color: #b45309;
}

.coupon-card__action {
  min-width: 132rpx;
  padding: 14rpx 0;
  border-radius: 999rpx;
  text-align: center;
  background: #ff4a43;
  color: #ffffff;
  font-size: 22rpx;
}

.coupon-card__action--selected {
  background: #fff1f0;
  color: #ff4a43;
}
