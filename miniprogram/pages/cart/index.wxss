.cart-screen {
  padding-bottom: 132rpx;
}

.cart-head__sub {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 18rpx;
}

.cart-head__count {
  font-size: 24rpx;
  color: #ff4a43;
}

.cart-head__action {
  font-size: 20rpx;
  color: #666666;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-card__desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.empty-card__action {
  display: inline-flex;
  margin-top: 28rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.cart-list-card {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.cart-item {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.cart-item__check {
  align-self: center;
  min-width: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #cccccc;
}

.cart-item__check--active {
  color: #ff4a43;
}

.cart-item__body {
  display: flex;
  flex: 1;
  gap: 14rpx;
}

.cart-item__cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  background: #e6eaf0;
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
}

.cart-item__content {
  flex: 1;
}

.cart-item__header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-item__name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.5;
  color: #333333;
}

.cart-item__delete {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #999999;
}

.cart-item__model {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.cart-item__meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #ff4a43;
}

.cart-item__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  gap: 20rpx;
}

.cart-item__qty-label {
  font-size: 20rpx;
  color: #888888;
}

.stepper {
  display: inline-flex;
  align-items: center;
  gap: 0;
  background: #f7f7f7;
  border-radius: 8rpx;
}

.stepper__btn,
.stepper__value {
  min-width: 48rpx;
  height: 48rpx;
  text-align: center;
  line-height: 48rpx;
  font-size: 22rpx;
}

.stepper__btn {
  color: #999999;
}

.stepper__value {
  color: #333333;
  font-weight: 500;
}

.invalid-card {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  background: #fff7f6;
}

.invalid-card:last-child {
  margin-bottom: 0;
}

.invalid-card__name {
  font-size: 22rpx;
  font-weight: 500;
  color: #a33b32;
}

.invalid-card__reason {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #999999;
}

.inline-action {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #fff1f0;
  color: #ff4a43;
  font-size: 20rpx;
}

.cart-toolbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 100rpx 1fr 190rpx;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -6rpx 18rpx rgba(31, 31, 31, 0.06);
}

.cart-toolbar__select,
.cart-toolbar__submit {
  padding: 18rpx 0;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
}

.cart-toolbar__select {
  color: #666666;
}

.cart-toolbar__submit {
  border-radius: 10rpx;
  background: #ff4a43;
  color: #ffffff;
}

.cart-toolbar__summary {
  text-align: left;
}

.cart-toolbar__amount {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
}

.cart-toolbar__desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #999999;
}
