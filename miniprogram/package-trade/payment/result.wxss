.result-screen {
  min-height: 100vh;
  background: #f5f5f5;
}

.result-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 80rpx 40rpx 0;
}

.result-panel__icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
}

.result-panel__icon--success {
  background: #e9f9ee;
}

.result-panel__icon--failed {
  background: #fff1f0;
}

.result-panel__icon--processing {
  background: #fff8e7;
}

.result-panel__title {
  font-size: 40rpx;
  font-weight: 700;
}

.result-panel__title--success {
  color: #16a34a;
}

.result-panel__title--failed {
  color: #ff4a43;
}

.result-panel__title--processing {
  color: #b45309;
}

.result-panel__summary {
  font-size: 24rpx;
  line-height: 1.7;
  color: #666666;
  text-align: center;
}

.result-panel__amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.result-panel__meta {
  font-size: 22rpx;
  color: #666666;
}

.result-panel__notice {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  background: #fff7ed;
  font-size: 22rpx;
  line-height: 1.7;
  color: #9a3412;
}

.result-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  width: 100%;
  margin-top: 16rpx;
}

.result-actions__ghost,
.result-actions__solid {
  padding: 20rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
}

.result-actions__ghost {
  background: #ffffff;
  border: 1rpx solid #dddddd;
  color: #555555;
}

.result-actions__solid {
  background: #ff3b30;
  color: #ffffff;
}

.result-debug {
  width: 100%;
  padding: 28rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.result-debug__label {
  font-size: 22rpx;
  color: #666666;
}

.result-debug__chips {
  margin-top: 18rpx;
}

.result-debug__chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  color: #666666;
  font-size: 22rpx;
}

.result-debug__chip--active {
  background: #fff1f0;
  color: #ff4a43;
}
