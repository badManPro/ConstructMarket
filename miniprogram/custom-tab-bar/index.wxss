.tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  padding: 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.92);
  box-shadow: 0 20rpx 50rpx rgba(15, 23, 42, 0.18);
  backdrop-filter: blur(16rpx);
}

.tabbar__item {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
}

.tabbar__item--active {
  background: #ffffff;
  color: #0f172a;
}

.tabbar__text {
  font-size: 24rpx;
  font-weight: 600;
}
