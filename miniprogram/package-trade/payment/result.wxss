.result-screen {
  min-height: 100vh;
  background: #f5f5f5;
}

.result-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 80rpx 40rpx 0;
}

.result-panel__icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
}

.result-panel__icon--success {
  background: #e9f9ee;
}

.result-panel__icon--failed {
  background: #fff1f0;
}

.result-panel__title {
  font-size: 40rpx;
  font-weight: 700;
}

.result-panel__title--success {
  color: #16a34a;
}

.result-panel__title--failed {
  color: #ff4a43;
}

.result-panel__summary {
  font-size: 22rpx;
  color: #666666;
}

.result-panel__amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.result-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  width: 100%;
  margin-top: 16rpx;
}

.result-actions__ghost,
.result-actions__solid {
  padding: 20rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
}

.result-actions__ghost {
  background: #ffffff;
  border: 1rpx solid #dddddd;
  color: #555555;
}

.result-actions__solid {
  background: #ff3b30;
  color: #ffffff;
}
