.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(15, 23, 42, 0.42);
}

.drawer-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: 82%;
  height: 100%;
  padding: 32rpx 28rpx 40rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.drawer-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-panel__title {
  font-size: 32rpx;
  font-weight: 700;
}

.drawer-panel__close {
  font-size: 24rpx;
  color: #64748b;
}

.drawer-section {
  margin-top: 36rpx;
}

.drawer-section__title {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.drawer-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.drawer-chip {
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
  font-size: 24rpx;
  color: #334155;
}

.drawer-chip--active {
  background: #dbeafe;
  color: #1d4ed8;
}

.drawer-actions {
  position: absolute;
  right: 28rpx;
  bottom: 40rpx;
  left: 28rpx;
  display: flex;
  gap: 16rpx;
}

.drawer-actions__ghost,
.drawer-actions__solid {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 20rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}

.drawer-actions__ghost {
  background: #e2e8f0;
  color: #334155;
}

.drawer-actions__solid {
  background: #0f172a;
  color: #ffffff;
}
