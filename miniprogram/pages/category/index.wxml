<view class="screen category-screen">
  <view class="page-head category-head">
    <view class="page-head__bar">
      <view class="page-head__title">选型</view>
      <view class="page-head__icon"></view>
    </view>

    <view class="category-search" bindtap="handleSearchTap">
      <view class="category-search__icon">搜索</view>
      <view class="category-search__text">搜索 {{searchPlaceholder}}</view>
      <view class="category-search__cta">去结果页</view>
    </view>

    <view class="page-head__sub">{{pageSubtitle}}</view>
  </view>

  <view class="category-layout">
    <scroll-view class="category-sidebar" scroll-y show-scrollbar="{{false}}">
      <view class="category-sidebar__inner">
        <view
          wx:for="{{rootCategories}}"
          wx:key="id"
          class="category-sidebar__item {{selectedCategoryId === item.id ? 'category-sidebar__item--active' : ''}}"
          data-id="{{item.id}}"
          bindtap="handleRootCategoryTap"
        >
          <view class="category-sidebar__name">{{item.name}}</view>
          <view class="category-sidebar__meta">{{item.summary}}</view>
        </view>
      </view>
    </scroll-view>

    <scroll-view class="category-main" scroll-y show-scrollbar="{{false}}">
      <view class="category-main__inner">
        <view wx:if="{{status === 'loading'}}" class="section-card">
          <view class="section-card__title">正在整理当前类目</view>
          <view class="section-card__meta">左侧类目、右侧细分类目和热销商品正在同步加载。</view>
          <view class="loading-grid">
            <view wx:for="{{loadingSkeleton}}" wx:key="*this" class="loading-grid__item"></view>
          </view>
        </view>

        <view wx:elif="{{status === 'error'}}" class="section-card empty-card">
          <view class="empty-card__title">分类内容读取失败</view>
          <view class="empty-card__desc">可先返回首页继续浏览，或重试当前类目内容加载。</view>
          <view class="empty-card__actions">
            <view class="empty-card__action empty-card__action--ghost" bindtap="handleGoHome">返回首页</view>
            <view class="empty-card__action" bindtap="handleRetry">重新加载</view>
          </view>
        </view>

        <view wx:elif="{{status === 'offline'}}" class="section-card empty-card">
          <view class="empty-card__title">当前处于离线演示态</view>
          <view class="empty-card__desc">离线占位已保留，恢复后可继续查看当前类目的细分和热销商品。</view>
          <view class="empty-card__actions">
            <view class="empty-card__action empty-card__action--ghost" bindtap="handleGoHome">返回首页</view>
            <view class="empty-card__action" bindtap="handleRetry">恢复内容</view>
          </view>
        </view>

        <view wx:elif="{{status === 'empty'}}" class="section-card empty-card">
          <view class="empty-card__title">该分类暂无商品</view>
          <view class="empty-card__desc">可以切换其他一级类目，或直接回到搜索结果页查看全部建材。</view>
          <view class="empty-card__actions">
            <view class="empty-card__action empty-card__action--ghost" bindtap="handleSearchTap">查看结果页</view>
            <view class="empty-card__action" bindtap="handleRetry">重新加载</view>
          </view>
        </view>

        <block wx:else>
          <view wx:if="{{currentCategory}}" class="section-card category-hero">
            <view class="category-hero__eyebrow">当前类目</view>
            <view class="category-hero__title">{{currentCategory.name}}</view>
            <view class="category-hero__summary">{{currentCategory.summary}}</view>

            <view class="chip-row">
              <view wx:for="{{currentCategory.sceneTags}}" wx:key="*this" class="route-chip">{{item}}</view>
            </view>

            <view class="category-hero__actions">
              <view class="category-hero__action category-hero__action--ghost" bindtap="handleOpenArticle">采购知识</view>
              <view class="category-hero__action" bindtap="handleOpenAllResults">查看全部结果</view>
            </view>
          </view>

          <view class="section-card">
            <view class="section-head">
              <view class="section-card__title">细分类目</view>
              <view class="section-head__more">{{subCategories.length}} 个</view>
            </view>

            <view class="subcategory-grid">
              <view
                wx:for="{{subCategories}}"
                wx:key="id"
                class="subcategory-tile"
                data-category-id="{{item.routeCategoryId}}"
                data-keyword="{{item.searchKeyword}}"
                bindtap="handleSubCategoryTap"
              >
                <view class="subcategory-tile__icon" style="background: {{item.iconTone}};">{{item.icon}}</view>
                <view class="subcategory-tile__name">{{item.name}}</view>
                <view class="subcategory-tile__summary">{{item.summary}}</view>
                <view class="subcategory-tile__badge">{{item.badge}}</view>
              </view>
            </view>
          </view>

          <view class="section-card">
            <view class="section-head">
              <view class="section-card__title">当前热销</view>
              <view class="section-head__more" bindtap="handleOpenAllResults">查看全部 ></view>
            </view>

            <view wx:if="{{currentCategory}}" class="section-card__meta">{{currentCategory.guideTitle}}</view>
            <view class="product-list">
              <product-card
                wx:for="{{categoryProducts}}"
                wx:key="id"
                item="{{item}}"
                bindtapcard="handleProductTap"
                bindfavorite="handleFavoriteTap"
              />
            </view>
          </view>

          <view wx:if="{{currentCategory}}" class="section-card guide-card" bindtap="handleOpenArticle">
            <view class="guide-card__eyebrow">采购建议</view>
            <view class="guide-card__title">{{currentCategory.guideTitle}}</view>
            <view class="guide-card__summary">{{currentCategory.guideSummary}}</view>
            <view class="guide-card__link">{{currentCategory.articleTitle}} ></view>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>
