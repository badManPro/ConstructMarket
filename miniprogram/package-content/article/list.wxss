.article-list-screen {
  padding-bottom: 48rpx;
}

.article-tabs {
  padding: 16rpx 24rpx 4rpx;
  white-space: nowrap;
}

.article-tabs__item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 12rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  color: #666666;
}

.article-tabs__item--active {
  background: #fff1f0;
  border-color: #ffd7d3;
  color: #ff4a43;
}

.article-tabs__label {
  font-size: 22rpx;
  font-weight: 500;
}

.article-tabs__count {
  font-size: 20rpx;
}

.article-note {
  margin-top: 12rpx;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.empty-card__desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.empty-card__actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-card__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.empty-card__action--ghost {
  background: #f4f4f4;
  color: #666666;
}

.featured-article__cover {
  display: flex;
  align-items: flex-end;
  height: 240rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  color: #7a3b24;
  box-sizing: border-box;
}

.featured-article__cover-text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 600;
}

.featured-article__meta,
.article-card__meta,
.featured-article__foot,
.article-card__foot,
.article-footer {
  font-size: 20rpx;
  color: #999999;
}

.featured-article__meta {
  margin-top: 18rpx;
}

.featured-article__title,
.article-card__title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #1f1f1f;
}

.featured-article__title {
  margin-top: 12rpx;
}

.featured-article__summary,
.article-card__summary {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.featured-article__foot,
.article-card__foot {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.article-card__body {
  display: flex;
  gap: 16rpx;
}

.article-card__cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 148rpx;
  min-width: 148rpx;
  height: 148rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #7a3b24;
}

.article-card__content {
  flex: 1;
}

.article-footer {
  margin: 20rpx 24rpx 0;
  text-align: center;
}
