.spec-mask {
  position: fixed;
  inset: 0;
  z-index: 45;
  background: rgba(0, 0, 0, 0.38);
}

.spec-panel {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  left: 16rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(31, 31, 31, 0.12);
}

.spec-panel__header {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.spec-panel__title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  color: #222222;
}

.spec-panel__price {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #ff4a43;
}

.spec-panel__close {
  font-size: 24rpx;
  color: #888888;
}

.spec-group {
  margin-top: 28rpx;
}

.spec-group__title {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #555555;
}

.spec-group__options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.spec-chip {
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  background: #f4f4f4;
  color: #666666;
  font-size: 22rpx;
}

.spec-chip--active {
  background: #fff1f0;
  color: #ff4a43;
}

.quantity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-row__btn,
.quantity-row__value {
  width: 68rpx;
  height: 68rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f4f4;
  font-size: 28rpx;
  font-weight: 600;
}

.quantity-row__hint {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #888888;
}

.spec-panel__footer {
  margin-top: 32rpx;
}

.spec-panel__summary {
  font-size: 22rpx;
  color: #666666;
}

.spec-panel__confirm {
  margin-top: 16rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #ff4a43;
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
}
