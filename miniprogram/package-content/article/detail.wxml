<view class="screen article-detail-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon" bindtap="handleGoBack">←</view>
      <view class="page-head__title">资讯详情</view>
      <view class="page-head__icon"></view>
    </view>
    <view wx:if="{{article}}" class="page-head__sub">{{article.categoryLabel}} · {{article.publishAt}}</view>
  </view>

  <view wx:if="{{status === 'loading'}}" class="section-card empty-card">
    <view class="empty-card__title">正文加载中</view>
    <view class="empty-card__desc">正在整理资讯正文和相关推荐内容。</view>
  </view>

  <view wx:elif="{{status === 'error'}}" class="section-card empty-card">
    <view class="empty-card__title">资讯详情读取失败</view>
    <view class="empty-card__desc">请重试正文加载，若仍异常可先返回资讯列表。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleGoArticleList">返回列表</view>
      <view class="empty-card__action" bindtap="handleRetry">重新加载</view>
    </view>
  </view>

  <view wx:elif="{{status === 'offline'}}" class="section-card empty-card">
    <view class="empty-card__title">当前处于离线阅读态</view>
    <view class="empty-card__desc">恢复后可继续查看正文和相关推荐。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleGoArticleList">返回列表</view>
      <view class="empty-card__action" bindtap="handleRetry">恢复阅读</view>
    </view>
  </view>

  <view wx:elif="{{status === 'empty'}}" class="section-card empty-card">
    <view class="empty-card__title">未找到对应资讯</view>
    <view class="empty-card__desc">可以返回资讯列表重新选择其他内容继续阅读。</view>
    <view class="empty-card__action" bindtap="handleGoArticleList">查看资讯列表</view>
  </view>

  <block wx:else>
    <view wx:if="{{article}}" class="section-card article-hero">
      <view class="article-hero__cover" style="background: {{article.tone}};">{{article.cover}}</view>
      <view class="chip-row">
        <view wx:for="{{article.tags}}" wx:key="*this" class="route-chip">{{item}}</view>
      </view>
      <view class="article-hero__title">{{article.title}}</view>
      <view class="article-hero__summary">{{article.summary}}</view>
      <view class="article-hero__meta">
        <view>{{article.source}}</view>
        <view>{{article.readingTime}}</view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__title title-with-badge">
        <text>正文内容</text>
        <text class="developing-badge">开发中</text>
      </view>
      <view wx:for="{{paragraphs}}" wx:key="index" class="article-paragraph">{{item}}</view>
    </view>

    <view wx:if="{{relatedArticles.length}}" class="section-card">
      <view class="section-card__title">相关推荐</view>
      <view class="link-list">
        <view
          wx:for="{{relatedArticles}}"
          wx:key="id"
          class="link-card"
          data-id="{{item.id}}"
          bindtap="handleOpenArticle"
        >
          <view class="link-card__title">{{item.categoryLabel}} · {{item.title}}</view>
          <view class="link-card__desc">{{item.summary}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
