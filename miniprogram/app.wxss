page {
  min-height: 100%;
  background: #f5f5f5;
  color: #1f1f1f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.screen {
  padding-bottom: 132rpx;
}

.page-head {
  background: #ffffff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.page-head__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  gap: 16rpx;
}

.page-head__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.title-with-badge {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.developing-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #d97706;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
}

.page-head__icon {
  min-width: 40rpx;
  font-size: 26rpx;
  color: #444444;
  text-align: center;
}

.page-head__sub {
  padding-bottom: 20rpx;
  font-size: 22rpx;
  color: #666666;
}

.hero {
  margin: 0;
  padding: 24rpx;
  background: #ffffff;
  color: #1f1f1f;
  border-bottom: 1rpx solid #f0f0f0;
}

.hero__eyebrow {
  font-size: 22rpx;
  color: #ff4a43;
}

.hero__title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.2;
}

.hero__subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #666666;
}

.section-card {
  margin: 16rpx 24rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 31, 31, 0.04);
}

.section-card__title {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.section-card__meta {
  margin-bottom: 16rpx;
  font-size: 22rpx;
  color: #888888;
}

.state-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.state-grid__item {
  padding: 18rpx 16rpx;
  border-radius: 12rpx;
  background: #f7f7f7;
}

.state-grid__value {
  font-size: 30rpx;
  font-weight: 600;
}

.state-grid__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #888888;
}

.bullet-list__item {
  position: relative;
  margin-bottom: 14rpx;
  padding-left: 22rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #444444;
}

.bullet-list__item:last-child {
  margin-bottom: 0;
}

.bullet-list__item::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 0;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #ff4a43;
}

.link-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.link-card {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f4f4f4;
}

.link-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.link-card__title {
  font-size: 26rpx;
  font-weight: 500;
  color: #222222;
}

.link-card__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #888888;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.route-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1f0;
  color: #ff4a43;
  font-size: 22rpx;
}
