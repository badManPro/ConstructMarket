.detail-screen {
  padding-bottom: 170rpx;
}

.detail-hero {
  overflow: hidden;
  margin: 16rpx 24rpx 0;
  border-radius: 12rpx;
  color: #ffffff;
}

.detail-hero__swiper {
  height: 520rpx;
}

.detail-hero__panel {
  height: 100%;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.detail-hero__eyebrow {
  font-size: 20rpx;
  opacity: 0.85;
}

.detail-hero__title {
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.detail-hero__subtitle {
  margin-top: 10rpx;
  max-width: 88%;
  font-size: 22rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.detail-price-card {
  margin-top: 16rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-header__price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff3b30;
}

.detail-header__unit {
  font-size: 22rpx;
  color: #999999;
}

.detail-header__stats {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #999999;
}

.detail-header__favorite {
  flex-shrink: 0;
  align-self: flex-start;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  color: #666666;
  font-size: 20rpx;
}

.detail-header__favorite--active {
  background: #fff1f0;
  color: #ff4a43;
}

.detail-header__title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
  color: #222222;
}

.detail-header__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag-row__item {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1f0;
  font-size: 20rpx;
  color: #ff4a43;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.detail-row__label {
  font-size: 22rpx;
  color: #555555;
}

.detail-row__value {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #222222;
}

.detail-row__arrow {
  color: #999999;
  font-size: 22rpx;
}

.detail-shop__name {
  font-size: 24rpx;
  font-weight: 600;
  color: #222222;
}

.detail-shop__meta {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.param-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.param-row:last-child {
  border-bottom: none;
}

.param-row__key {
  font-size: 22rpx;
  color: #666666;
}

.param-row__value {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  color: #222222;
}

.detail-delivery {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #666666;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-toolbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 92rpx 140rpx 180rpx 1fr;
  gap: 8rpx;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -6rpx 18rpx rgba(31, 31, 31, 0.06);
}

.detail-toolbar__aside,
.detail-toolbar__cart,
.detail-toolbar__ghost,
.detail-toolbar__solid {
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-toolbar__aside,
.detail-toolbar__cart {
  background: #fff1f1;
  color: #ff3b30;
}

.detail-toolbar__ghost {
  background: #ffe8d9;
  color: #e06a00;
}

.detail-toolbar__solid {
  background: #ff3b30;
  color: #ffffff;
}
