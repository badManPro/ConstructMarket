.order-detail-screen {
  padding-bottom: 132rpx;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.empty-card__desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.empty-card__actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-card__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.empty-card__action--ghost {
  background: #f4f4f4;
  color: #666666;
}

.order-status-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-status-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4a43;
}

.order-status-card__time {
  font-size: 20rpx;
  color: #999999;
}

.order-status-card__desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #444444;
}

.trade-row__value {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.6;
  color: #222222;
}

.trade-row__desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #666666;
}

.trade-row__tag {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  font-size: 20rpx;
  color: #666666;
}

.detail-item {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-item__cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  background: #eceff3;
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-item__content {
  flex: 1;
}

.detail-item__name {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.5;
  color: #222222;
}

.detail-item__model {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.detail-item__meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #ff4a43;
}

.summary-row,
.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child,
.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.summary-row__label,
.info-row__label {
  font-size: 22rpx;
  color: #666666;
}

.summary-row__value,
.info-row__value {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  line-height: 1.6;
  color: #222222;
}

.summary-row--strong .summary-row__label,
.summary-row--strong .summary-row__value {
  font-size: 24rpx;
  font-weight: 600;
}

.detail-toolbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -6rpx 18rpx rgba(31, 31, 31, 0.06);
}

.detail-toolbar__ghost,
.detail-toolbar__solid {
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
}

.detail-toolbar__ghost {
  background: #f4f4f4;
  color: #666666;
}

.detail-toolbar__solid {
  background: #ff4a43;
  color: #ffffff;
}
