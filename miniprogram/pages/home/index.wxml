<view class="screen home-screen">
  <view class="home-header">
    <view class="home-header__row">
      <view class="home-header__city">{{cityLabel}} ▾</view>
      <view class="home-header__badge">{{messageBadge}}</view>
    </view>

    <view class="home-search" bindtap="handleSearchTap">
      <view class="home-search__icon">搜索</view>
      <view class="home-search__text">搜索建材 / 品牌 / 型号</view>
    </view>

    <view class="chip-row home-chip-row">
      <view
        wx:for="{{keywordSuggestions}}"
        wx:key="*this"
        class="route-chip"
        data-keyword="{{item}}"
        bindtap="handleKeywordTap"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="home-banner-wrap">
    <swiper class="banner-swiper" indicator-dots circular autoplay interval="4200">
      <view wx:for="{{banners}}" wx:key="id" wx:for-item="banner">
        <view
          class="banner-card"
          style="background: {{banner.accent}};"
          data-route="{{banner.route}}"
          data-params="{{banner.params}}"
          bindtap="handleBannerTap"
        >
          <view class="banner-card__eyebrow">{{banner.eyebrow}}</view>
          <view class="banner-card__title">{{banner.title}}</view>
          <view class="banner-card__subtitle">{{banner.subtitle}}</view>
          <view class="banner-card__action">{{banner.actionText}}</view>
        </view>
      </view>
    </swiper>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-card__title">快捷选型</view>
      <view class="section-head__more" data-route="/pages/category/index" bindtap="handleRouteTap">查看更多 ></view>
    </view>
    <view class="category-grid">
      <view
        wx:for="{{categoryNav}}"
        wx:key="id"
        wx:for-index="index"
        class="category-tile"
        data-route="{{item.route}}"
        data-params="{{item.params}}"
        bindtap="handleCategoryTap"
      >
        <view class="category-tile__icon category-tile__icon--{{index}}">{{item.shortName}}</view>
        <view class="category-tile__name">{{item.name}}</view>
        <view class="category-tile__tagline">{{item.tagline}}</view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-card__title">尖货榜单 限时抢</view>
      <view class="section-head__more">查看更多 ></view>
    </view>
    <view class="section-card__meta">优先展示当前工程采购场景里的主推组合。</view>
    <view class="product-list">
      <product-card
        wx:for="{{campaignProducts}}"
        wx:key="id"
        item="{{item}}"
        bindtapcard="handleProductTap"
        bindfavorite="handleFavoriteTap"
      />
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-card__title">热门商品推荐</view>
      <view class="section-head__more">查看更多 ></view>
    </view>
    <view class="section-card__meta">用于验证首页到详情页的主流跳转链路。</view>
    <view class="product-list">
      <product-card
        wx:for="{{hotProducts}}"
        wx:key="id"
        item="{{item}}"
        bindtapcard="handleProductTap"
        bindfavorite="handleFavoriteTap"
      />
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-card__title">建材资讯</view>
      <view class="section-head__more" data-route="/package-content/article/list" bindtap="handleRouteTap">查看更多 ></view>
    </view>
    <view class="link-list">
      <view
        wx:for="{{articleEntrances}}"
        wx:key="id"
        class="link-card"
        data-route="{{item.route}}"
        data-params="{{item.params}}"
        bindtap="handleArticleTap"
      >
        <view class="link-card__title">{{item.category}} · {{item.title}}</view>
        <view class="link-card__desc">{{item.summary}}</view>
      </view>
    </view>
  </view>
</view>
