page {
  min-height: 100%;
  background: #f5f7fa;
  color: #0f172a;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.screen {
  padding: 32rpx;
  padding-bottom: 176rpx;
}

.hero {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0f172a, #1e293b);
  color: #ffffff;
}

.hero__eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.7;
  text-transform: uppercase;
}

.hero__title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero__subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.88;
}

.section-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.section-card__title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.section-card__meta {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #64748b;
}

.state-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.state-grid__item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.state-grid__value {
  font-size: 32rpx;
  font-weight: 700;
}

.state-grid__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.bullet-list__item {
  position: relative;
  margin-bottom: 14rpx;
  padding-left: 22rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #334155;
}

.bullet-list__item:last-child {
  margin-bottom: 0;
}

.bullet-list__item::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 0;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #2563eb;
}

.link-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.link-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.link-card__title {
  font-size: 28rpx;
  font-weight: 600;
}

.link-card__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.route-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 24rpx;
}
