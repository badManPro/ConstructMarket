<view class="screen result-screen">
  <view class="result-card">
    <view class="result-card__badge {{status === 'success' ? 'result-card__badge--success' : 'result-card__badge--failed'}}">
      {{status === 'success' ? '成功' : '失败'}}
    </view>
    <view class="result-card__title">{{title}}</view>
    <view class="result-card__summary">{{summary}}</view>
    <view class="result-card__amount">¥{{amount}}</view>
  </view>

  <view class="section-card">
    <view class="section-card__title">本次结果</view>
    <view class="result-row">
      <view class="result-row__label">订单号</view>
      <view class="result-row__value">{{orderNo}}</view>
    </view>
    <view class="result-row">
      <view class="result-row__label">支付金额</view>
      <view class="result-row__value">¥{{amount}}</view>
    </view>
  </view>

  <view class="result-actions">
    <view class="result-actions__ghost" bindtap="handleGoHome">返回首页</view>
    <view wx:if="{{status === 'success'}}" class="result-actions__solid" bindtap="handleGoCart">回购物车</view>
    <view wx:else class="result-actions__solid" bindtap="handleBackCheckout">返回结算</view>
  </view>
</view>
