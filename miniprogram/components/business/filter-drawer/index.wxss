.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(0, 0, 0, 0.34);
}

.drawer-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: 79%;
  height: 100%;
  padding: 24rpx 24rpx 32rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.drawer-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-panel__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.drawer-panel__close {
  font-size: 24rpx;
  color: #888888;
}

.drawer-section {
  margin-top: 36rpx;
}

.drawer-section__title {
  margin-bottom: 18rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #555555;
}

.drawer-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.drawer-chip {
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  background: #f4f4f4;
  font-size: 22rpx;
  color: #666666;
}

.drawer-chip--active {
  background: #fff1f0;
  color: #ff4a43;
}

.drawer-actions {
  position: absolute;
  right: 28rpx;
  bottom: 40rpx;
  left: 28rpx;
  display: flex;
  gap: 16rpx;
}

.drawer-actions__ghost,
.drawer-actions__solid {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 10rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
}

.drawer-actions__ghost {
  background: #f4f4f4;
  color: #666666;
}

.drawer-actions__solid {
  background: #ff4a43;
  color: #ffffff;
}
