.home-screen {
  background: #f5f5f5;
}

.home-header {
  padding: 20rpx 24rpx 24rpx;
  background: #ffffff;
}

.home-header__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.home-header__city {
  font-size: 22rpx;
  color: #666666;
}

.home-header__badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
}

.home-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #f1f2f5;
}

.home-search__icon {
  font-size: 20rpx;
  color: #a0a0a0;
}

.home-search__text {
  font-size: 22rpx;
  color: #9a9a9a;
}

.home-chip-row {
  margin-top: 14rpx;
}

.home-banner-wrap {
  margin: 16rpx 24rpx 0;
}

.home-state-card {
  text-align: center;
}

.home-state-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.home-state-actions__ghost,
.home-state-actions__solid {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.home-state-actions__ghost {
  background: #f4f4f4;
  color: #666666;
}

.home-state-actions__solid {
  background: #ff4a43;
  color: #ffffff;
}

.banner-swiper {
  height: 240rpx;
}

.banner-card {
  position: relative;
  height: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.banner-card--image {
  color: #ffffff;
}

.banner-card--text {
  color: #702626;
}

.banner-card__image,
.banner-card__scrim {
  position: absolute;
  inset: 0;
}

.banner-card__image {
  width: 100%;
  height: 100%;
}

.banner-card__scrim {
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.18), rgba(15, 23, 42, 0.56));
}

.banner-card__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  padding: 28rpx 26rpx;
  box-sizing: border-box;
}

.banner-card__eyebrow {
  font-size: 20rpx;
  color: inherit;
  opacity: 0.88;
}

.banner-card__title {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.banner-card__subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: inherit;
  opacity: 0.88;
}

.banner-card__action {
  display: inline-flex;
  align-self: flex-start;
  margin-top: 18rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  font-size: 20rpx;
  color: #7c2d12;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.section-head__more {
  font-size: 20rpx;
  color: #999999;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx 12rpx;
}

.category-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.category-tile__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8a4b3a;
}

.category-tile__icon--0 {
  background: #ffe9e2;
}

.category-tile__icon--1 {
  background: #fff1d8;
}

.category-tile__icon--2 {
  background: #e7f3ff;
}

.category-tile__icon--3 {
  background: #eaf7ec;
}

.category-tile__name {
  font-size: 22rpx;
  font-weight: 500;
  color: #333333;
  text-align: center;
}

.category-tile__tagline {
  font-size: 18rpx;
  color: #999999;
  text-align: center;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
