.profile-state-card {
  margin-top: 24rpx;
}

.profile-hero {
  padding: 24rpx 24rpx 0;
}

.profile-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #3b3d43 0%, #494d57 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(31, 31, 31, 0.12);
}

.profile-card__main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-card__avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 34rpx;
  font-weight: 600;
}

.profile-card__info {
  flex: 1;
  min-width: 0;
}

.profile-card__name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.profile-card__name {
  font-size: 32rpx;
  font-weight: 600;
}

.profile-card__role {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 20rpx;
  color: #ffe4d5;
}

.profile-card__phone,
.profile-card__company {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.profile-card__cta {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #ff6a55;
  font-size: 22rpx;
  font-weight: 500;
  color: #ffffff;
}

.profile-card__note {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #ffe4d5;
}

.profile-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.profile-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.86);
}

.profile-assets {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.profile-asset {
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(31, 31, 31, 0.05);
}

.profile-asset__value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.profile-asset__label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.profile-section {
  margin-top: 18rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-link {
  font-size: 22rpx;
  color: #ff4a43;
}

.order-shortcuts {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.order-shortcut {
  padding: 16rpx 10rpx;
  border-radius: 14rpx;
  background: #f7f7f7;
  text-align: center;
}

.order-shortcut__count {
  font-size: 32rpx;
  font-weight: 600;
  color: #999999;
}

.order-shortcut__count--active {
  color: #ff4a43;
}

.order-shortcut__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #222222;
}

.order-shortcut__hint {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #999999;
}

.service-list {
  display: flex;
  flex-direction: column;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.service-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.service-item__body {
  flex: 1;
  min-width: 0;
}

.service-item__title {
  font-size: 26rpx;
  font-weight: 500;
  color: #222222;
}

.service-item__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #888888;
}

.service-item__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.service-item__badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  font-size: 20rpx;
  color: #666666;
}

.service-item__badge--accent {
  background: #fff1f0;
  color: #ff4a43;
}

.service-item__arrow {
  font-size: 26rpx;
  color: #bbbbbb;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.empty-card__desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.empty-card__actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-card__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.empty-card__action--ghost {
  background: #f4f4f4;
  color: #666666;
}
