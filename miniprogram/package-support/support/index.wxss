.support-screen {
  padding-bottom: 48rpx;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.empty-card__desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.empty-card__actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-card__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.empty-card__action--ghost {
  background: #f4f4f4;
  color: #666666;
}

.support-note__desc {
  font-size: 22rpx;
  line-height: 1.7;
  color: #444444;
}

.support-card {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.support-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  min-width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #ff4a43;
  font-size: 28rpx;
  font-weight: 700;
}

.support-card__content {
  flex: 1;
}

.support-card__head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.support-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.support-card__badge {
  font-size: 20rpx;
  color: #ff4a43;
}

.support-card__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}
