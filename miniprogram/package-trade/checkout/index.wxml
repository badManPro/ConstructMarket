<view class="screen checkout-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon" bindtap="handleGoBack">←</view>
      <view class="page-head__title">确认订单</view>
      <view class="page-head__icon"></view>
    </view>
  </view>

  <view wx:if="{{status === 'loading'}}" class="section-card empty-card">
    <view class="empty-card__title">正在整理结算信息</view>
    <view class="empty-card__desc">收货地址、优惠券和发票信息正在从本地状态汇总。</view>
  </view>

  <view wx:elif="{{status === 'error'}}" class="section-card empty-card">
    <view class="empty-card__title">结算页初始化失败</view>
    <view class="empty-card__desc">本地交易草稿读取异常，请返回购物车后重试。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleBackCart">返回购物车</view>
      <view class="empty-card__action" bindtap="handleRetry">重新加载</view>
    </view>
  </view>

  <view wx:elif="{{status === 'offline'}}" class="section-card empty-card">
    <view class="empty-card__title">当前处于离线演示态</view>
    <view class="empty-card__desc">结算草稿已保留在本地，恢复网络后可继续提交订单。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleBackCart">返回购物车</view>
      <view class="empty-card__action" bindtap="handleRetry">恢复页面</view>
    </view>
  </view>

  <block wx:elif="{{status === 'empty'}}">
    <view class="section-card empty-card">
      <view class="empty-card__title">当前没有待结算商品</view>
      <view class="empty-card__desc">先从商品详情直接购买，或在购物车中勾选商品后再进入结算页。</view>
      <view class="empty-card__actions">
        <view class="empty-card__action empty-card__action--ghost" bindtap="handleBackCart">回购物车</view>
        <view class="empty-card__action" bindtap="handleGoHome">去首页</view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="section-card checkout-source-card">
      <view class="checkout-source-card__text">当前来源：{{sourceLabel}}</view>
    </view>

    <view class="section-card" data-route="/package-profile/profile/address/list" bindtap="handleRouteTap">
      <view class="trade-row">
        <view class="trade-row__main">
          <view wx:if="{{selectedAddress}}" class="trade-row__value">收货人：{{selectedAddress.receiver}} {{selectedAddress.phone}}</view>
          <view wx:if="{{selectedAddress}}" class="trade-row__desc">地址：{{addressText}}</view>
          <view wx:if="{{selectedAddress}}" class="trade-row__tag">{{selectedAddress.tag}}</view>
          <view wx:else class="trade-row__warn">暂无地址，请先新增</view>
        </view>
        <view class="trade-row__arrow">></view>
      </view>
    </view>

    <view class="section-card">
      <view wx:for="{{items}}" wx:key="id" class="checkout-item">
        <view class="checkout-item__cover">{{item.cover}}</view>
        <view class="checkout-item__content">
          <view class="checkout-item__name">{{item.name}}</view>
          <view class="checkout-item__model">{{item.model}}</view>
          <view class="checkout-item__meta">¥{{item.price}} x {{item.quantity}}</view>
        </view>
      </view>
    </view>

    <view class="section-card" data-route="/package-profile/profile/coupon" bindtap="handleRouteTap">
      <view class="trade-row">
        <view class="trade-row__main">
          <view class="trade-row__label">优惠券</view>
          <view wx:if="{{selectedCoupon}}" class="trade-row__value">{{selectedCoupon.name}}</view>
          <view wx:if="{{selectedCoupon}}" class="trade-row__desc">已抵扣 ¥{{selectedCoupon.amount}}，门槛 ¥{{selectedCoupon.threshold}}</view>
          <view wx:elif="{{recommendedCoupon}}" class="trade-row__desc">推荐 {{recommendedCoupon.name}}，当前可抵扣 ¥{{recommendedCoupon.amount}}</view>
          <view wx:else class="trade-row__desc">当前暂无可用优惠券，后续可从优惠券页回流</view>
        </view>
        <view class="trade-row__arrow">></view>
      </view>

      <view wx:if="{{recommendedCoupon && !selectedCoupon}}" class="trade-action-row">
        <view class="route-chip" catchtap="handleApplyRecommendedCoupon">使用推荐券</view>
      </view>

      <view wx:if="{{selectedCoupon}}" class="trade-action-row">
        <view class="route-chip" catchtap="handleClearCoupon">不使用优惠券</view>
      </view>
    </view>

    <view class="section-card" data-route="/package-profile/profile/invoice" bindtap="handleRouteTap">
      <view class="trade-row">
        <view class="trade-row__main">
          <view class="trade-row__label">发票信息</view>
          <view class="trade-row__value">{{invoiceText}}</view>
          <view wx:if="{{invoiceDraft}}" class="trade-row__desc">{{invoiceDraft.taxNo}} · {{invoiceDraft.email}}</view>
        </view>
        <view class="trade-row__arrow">></view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__title">订单备注</view>
      <textarea
        class="remark-input"
        maxlength="60"
        auto-height
        placeholder="可填写收货时间、上楼要求或项目备注"
        value="{{remark}}"
        bindinput="handleRemarkInput"
      />
    </view>

    <view class="section-card">
      <view class="section-card__title">支付方式</view>
      <view class="payment-list">
        <view
          wx:for="{{paymentMethods}}"
          wx:key="code"
          class="payment-card {{selectedPaymentMethod === item.code ? 'payment-card--active' : ''}}"
          data-code="{{item.code}}"
          bindtap="handlePaymentMethodTap"
        >
          <view class="payment-card__title">{{item.name}}</view>
          <view class="payment-card__desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__title">联调模拟</view>

      <view class="debug-row">
        <view class="trade-row__label">提交订单</view>
        <view class="chip-row">
          <view
            class="debug-chip {{submitMode === 'normal' ? 'debug-chip--active' : ''}}"
            data-mode="normal"
            bindtap="handleSubmitModeTap"
          >
            正常提交
          </view>
          <view
            class="debug-chip {{submitMode === 'submit_failed' ? 'debug-chip--active' : ''}}"
            data-mode="submit_failed"
            bindtap="handleSubmitModeTap"
          >
            模拟提交失败
          </view>
        </view>
        <view wx:if="{{submitErrorText}}" class="trade-row__warn">{{submitErrorText}}</view>
      </view>

      <view class="debug-row">
        <view class="trade-row__label">支付结果</view>
        <view class="chip-row">
          <view
            class="debug-chip {{paymentResultMode === 'success' ? 'debug-chip--active' : ''}}"
            data-mode="success"
            bindtap="handlePaymentResultModeTap"
          >
            支付成功
          </view>
          <view
            class="debug-chip {{paymentResultMode === 'processing' ? 'debug-chip--active' : ''}}"
            data-mode="processing"
            bindtap="handlePaymentResultModeTap"
          >
            支付中
          </view>
          <view
            class="debug-chip {{paymentResultMode === 'failed' ? 'debug-chip--active' : ''}}"
            data-mode="failed"
            bindtap="handlePaymentResultModeTap"
          >
            支付失败
          </view>
        </view>
        <view class="trade-row__desc">当前 Mock 订单提交后会带入选中的支付结果态，便于联调订单回流。</view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__title">金额明细</view>
      <view class="summary-row">
        <view class="summary-row__label">商品金额</view>
        <view class="summary-row__value">¥{{amountSummary.subtotal}}</view>
      </view>
      <view class="summary-row">
        <view class="summary-row__label">优惠抵扣</view>
        <view class="summary-row__value">-¥{{amountSummary.discount}}</view>
      </view>
      <view class="summary-row">
        <view class="summary-row__label">运费</view>
        <view class="summary-row__value">¥{{amountSummary.freight}}</view>
      </view>
      <view class="summary-row summary-row--strong">
        <view class="summary-row__label">应付金额</view>
        <view class="summary-row__value">¥{{amountSummary.payable}}</view>
      </view>
    </view>

    <view class="checkout-toolbar">
      <view class="checkout-toolbar__summary">
        <view class="checkout-toolbar__amount">应付 ¥{{amountSummary.payable}}</view>
        <view class="checkout-toolbar__desc">{{items.length}} 行商品待提交</view>
      </view>
      <view class="checkout-toolbar__submit" bindtap="handleSubmitOrder">
        {{submitting ? '提交中...' : '提交订单'}}
      </view>
    </view>
  </block>
</view>
