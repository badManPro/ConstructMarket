<view class="screen">
  <view class="hero">
    <view class="hero__eyebrow">ConstructMarket</view>
    <view class="hero__title">{{title}}</view>
    <view class="hero__subtitle">{{summary}}</view>
  </view>

  <view class="section-card">
    <view class="section-card__title">项目概览</view>
    <view class="state-grid">
      <view wx:for="{{highlights}}" wx:key="label" class="state-grid__item">
        <view class="state-grid__value">{{item.value}}</view>
        <view class="state-grid__label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view wx:for="{{sections}}" wx:key="title" class="section-card">
    <view class="section-card__title">{{item.title}}</view>
    <view class="link-list">
      <view
        wx:for="{{item.links}}"
        wx:key="route"
        class="link-card"
        data-route="{{item.route}}"
        bindtap="handleRouteTap"
      >
        <view class="link-card__title">{{item.label}}</view>
        <view class="link-card__desc">{{item.description}}</view>
      </view>
    </view>
  </view>
</view>
