<view class="screen faq-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon" bindtap="handleGoBack">←</view>
      <view class="page-head__title title-with-badge">
        <text>常见问题</text>
        <text class="developing-badge">开发中</text>
      </view>
      <view class="page-head__icon"></view>
    </view>
    <view class="page-head__sub">先用 FAQ 自助定位支付、发票和配送问题。</view>
  </view>

  <scroll-view class="faq-tabs" scroll-x enable-flex show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="value"
      class="faq-tabs__item {{currentCategory === item.value ? 'faq-tabs__item--active' : ''}}"
      data-value="{{item.value}}"
      bindtap="handleCategoryTap"
    >
      <view class="faq-tabs__label">{{item.label}}</view>
      <view class="faq-tabs__count">{{item.count}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{status === 'loading'}}" class="section-card empty-card">
    <view class="empty-card__title">FAQ 加载中</view>
    <view class="empty-card__desc">正在整理当前分类下的问题和答案。</view>
  </view>

  <view wx:elif="{{status === 'error'}}" class="section-card empty-card">
    <view class="empty-card__title">FAQ 读取失败</view>
    <view class="empty-card__desc">请重试本地问答加载，若仍异常可直接进入在线咨询。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleGoChat">在线咨询</view>
      <view class="empty-card__action" bindtap="handleRetry">重新加载</view>
    </view>
  </view>

  <view wx:elif="{{status === 'offline'}}" class="section-card empty-card">
    <view class="empty-card__title">当前 FAQ 不可用</view>
    <view class="empty-card__desc">恢复后可继续查看问答内容，或稍后改走在线咨询。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleGoBack">返回上一页</view>
      <view class="empty-card__action" bindtap="handleRetry">恢复 FAQ</view>
    </view>
  </view>

  <view wx:elif="{{status === 'empty'}}" class="section-card empty-card">
    <view class="empty-card__title">当前分类暂无问题</view>
    <view class="empty-card__desc">可以切换其他分类，或直接进入在线咨询补充问题。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleRetry">重新加载</view>
      <view class="empty-card__action" bindtap="handleGoChat">在线咨询</view>
    </view>
  </view>

  <block wx:else>
    <view class="section-card faq-note">
      <view class="section-card__title">使用建议</view>
      <view class="section-card__meta">若当前问题仍无法定位，可以从页面底部进入在线咨询继续追问。</view>
    </view>

    <view wx:for="{{faqs}}" wx:key="id" class="section-card faq-card" data-id="{{item.id}}" bindtap="handleToggle">
      <view class="faq-card__head">
        <view class="faq-card__question">{{item.question}}</view>
        <view class="faq-card__toggle">{{item.expanded ? '−' : '+'}}</view>
      </view>
      <view wx:if="{{item.expanded}}" class="faq-card__answer">{{item.answer}}</view>
    </view>

    <view class="faq-footer" bindtap="handleGoChat">仍未解决？去在线咨询</view>
  </block>
</view>
