.search-panel-card {
  margin-top: 12rpx;
}

.search-panel {
  display: flex;
  gap: 16rpx;
}

.search-panel__input {
  flex: 1;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 34rpx;
  background: #f1f2f5;
  font-size: 24rpx;
}

.search-panel__button {
  padding: 18rpx 28rpx;
  border-radius: 34rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.search-summary {
  font-size: 20rpx;
  color: #666666;
}

.toolbar-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 10rpx;
}

.toolbar-row__action {
  font-size: 20rpx;
  color: #666666;
}

.category-scroll {
  margin-top: 12rpx;
  white-space: nowrap;
}

.category-scroll__inner {
  display: inline-flex;
  gap: 22rpx;
}

.category-pill,
.sort-pill {
  padding: 0;
  border-radius: 0;
  background: transparent;
  font-size: 20rpx;
  color: #666666;
}

.category-pill--active,
.sort-pill--active {
  color: #ff4a43;
}

.sort-row {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.sort-pill--filter {
  color: #666666;
}

.results-meta {
  margin-top: 14rpx;
  font-size: 20rpx;
  color: #888888;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-product-list {
  margin: 16rpx 24rpx 0;
}

.empty-card {
  text-align: center;
}

.empty-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.empty-actions--single {
  margin-top: 16rpx;
}

.empty-actions__ghost,
.empty-actions__solid,
.empty-actions__link {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.empty-actions__ghost {
  background: #f4f4f4;
  color: #666666;
}

.empty-actions__solid {
  background: #ff4a43;
  color: #ffffff;
}

.empty-actions__link {
  background: #fff1f0;
  color: #ff4a43;
}

.category-drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 35;
  background: rgba(0, 0, 0, 0.4);
}

.category-drawer {
  position: absolute;
  right: 14rpx;
  left: 14rpx;
  top: 120rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(31, 31, 31, 0.14);
}

.category-drawer__title {
  margin-bottom: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #666666;
}

.category-drawer__grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx 12rpx;
}

.category-drawer__chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0;
  background: transparent;
  font-size: 20rpx;
}

.category-drawer__chip--active {
  color: #ff4a43;
}

.category-drawer__thumb {
  width: 100%;
  height: 96rpx;
  border-radius: 8rpx;
  background: #f4f4f4;
}

.category-drawer__label {
  color: inherit;
}

.category-drawer__submit {
  margin-top: 20rpx;
  padding: 18rpx 0;
  border-radius: 10rpx;
  background: #ff4a43;
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
}
