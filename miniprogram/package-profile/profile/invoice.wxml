<view class="screen invoice-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon" bindtap="handleGoBack">←</view>
      <view class="page-head__title">发票中心</view>
      <view class="page-head__icon"></view>
    </view>
    <view class="page-head__sub">
      {{scene === 'checkout' ? '编辑发票信息后会直接回流到结算页。' : '管理电子发票、纸质发票与申请记录。'}}
    </view>
  </view>

  <view class="invoice-tabs">
    <view class="invoice-tabs__item {{activeTab === 'electronic' ? 'invoice-tabs__item--active' : ''}}" data-value="electronic" bindtap="handleTabTap">电子发票</view>
    <view class="invoice-tabs__item {{activeTab === 'paper' ? 'invoice-tabs__item--active' : ''}}" data-value="paper" bindtap="handleTabTap">纸质发票</view>
    <view class="invoice-tabs__item {{activeTab === 'manage' ? 'invoice-tabs__item--active' : ''}}" data-value="manage" bindtap="handleTabTap">发票管理</view>
  </view>

  <block wx:if="{{activeTab === 'manage'}}">
    <view wx:if="{{!invoiceRecords.length}}" class="section-card empty-card">
      <view class="empty-card__title">还没有发票记录</view>
      <view class="empty-card__desc">先在订单申请开票，记录会在这里集中展示。</view>
    </view>

    <view wx:for="{{invoiceRecords}}" wx:key="id" class="section-card invoice-record">
      <view class="invoice-record__head">
        <view class="invoice-record__title">{{item.typeText}}</view>
        <view class="invoice-record__status">{{item.statusText}}</view>
      </view>
      <view class="invoice-record__desc">订单号：{{item.orderNo}}</view>
      <view class="invoice-record__desc">抬头：{{item.title}}</view>
      <view class="invoice-record__desc">税号：{{item.taxNo}}</view>
      <view class="invoice-record__desc">邮箱：{{item.email}}</view>
      <view class="invoice-record__desc">申请时间：{{item.applyAt}}</view>
    </view>
  </block>

  <block wx:else>
    <view class="section-card">
      <view class="section-card__title">{{activeTab === 'paper' ? '纸质发票信息' : '电子发票信息'}}</view>
      <view class="form-item">
        <view class="form-item__label">发票抬头</view>
        <input class="form-item__input" placeholder="请输入公司名称或个人抬头" value="{{formDraft.title}}" data-field="title" bindinput="handleInput" />
      </view>
      <view class="form-item">
        <view class="form-item__label">税号</view>
        <input class="form-item__input" placeholder="请输入纳税人识别号" value="{{formDraft.taxNo}}" data-field="taxNo" bindinput="handleInput" />
      </view>
      <view class="form-item">
        <view class="form-item__label">{{activeTab === 'paper' ? '通知邮箱' : '接收邮箱'}}</view>
        <input class="form-item__input" placeholder="请输入邮箱地址" value="{{formDraft.email}}" data-field="email" bindinput="handleInput" />
      </view>
      <view class="invoice-form__hint">
        {{activeTab === 'paper' ? '纸质发票将按订单收货地址寄送，邮箱用于同步申请通知。' : '电子发票会发送到该邮箱并在管理页留档。'}}
      </view>
      <view class="invoice-form__submit" bindtap="handleSaveInvoice">
        {{scene === 'checkout' ? '保存并回流结算页' : '提交开票申请'}}
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__title">可开票订单</view>
      <view wx:if="{{!invoiceCandidates.length}}" class="invoice-form__hint">当前暂无已支付订单可用于开票。</view>
      <view wx:for="{{invoiceCandidates}}" wx:key="id" class="invoice-candidate">
        <view class="invoice-candidate__head">
          <view class="invoice-candidate__order-no">{{item.orderNo}}</view>
          <view class="invoice-candidate__amount">¥{{item.amount.payable}}</view>
        </view>
        <view class="invoice-candidate__desc">{{item.address.receiver}} · {{item.address.phone}}</view>
        <view class="invoice-candidate__desc">{{item.addressText}}</view>
        <view class="invoice-candidate__action" data-id="{{item.id}}" bindtap="handleOpenOrder">查看订单</view>
      </view>
    </view>
  </block>
</view>
