.home-screen {
  background: #f5f5f5;
}

.home-header {
  padding: 20rpx 24rpx 16rpx;
  background: #ffffff;
}

.home-header__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.home-header__city {
  font-size: 22rpx;
  color: #666666;
}

.home-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #f1f2f5;
}

.home-search__icon {
  font-size: 20rpx;
  color: #a0a0a0;
}

.home-search__text {
  font-size: 22rpx;
  color: #9a9a9a;
}

.home-banner-wrap {
  margin: 12rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.12);
}

.home-state-card {
  text-align: center;
}

.home-state-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.home-state-actions__ghost,
.home-state-actions__solid {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.home-state-actions__ghost {
  background: #f4f4f4;
  color: #666666;
}

.home-state-actions__solid {
  background: #ff4a43;
  color: #ffffff;
}

.banner-swiper {
  height: 280rpx;
}

.banner-card {
  position: relative;
  height: 100%;
  box-sizing: border-box;
  color: #ffffff;
}

.banner-card--image {
  background: #0f172a;
}

.banner-card__image,
.banner-card__scrim,
.banner-card__glow {
  position: absolute;
  inset: 0;
}

.banner-card__image {
  width: 100%;
  height: 100%;
}

.banner-card__scrim {
  background: linear-gradient(90deg, rgba(2, 6, 23, 0.82), rgba(15, 23, 42, 0.54) 56%, rgba(15, 23, 42, 0.16));
}

.banner-card--text .banner-card__scrim {
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(30, 41, 59, 0.82) 58%, rgba(51, 65, 85, 0.68));
}

.banner-card__glow {
  opacity: 0.88;
  background:
    radial-gradient(circle at 88% 24%, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0) 28%),
    radial-gradient(circle at 74% 82%, rgba(251, 113, 133, 0.24), rgba(251, 113, 133, 0) 34%);
}

.banner-card__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  height: 100%;
  padding: 30rpx 30rpx 34rpx;
  box-sizing: border-box;
}

.banner-card__eyebrow {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  font-size: 20rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.92);
}

.banner-card__title {
  margin-top: 18rpx;
  max-width: 500rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.28;
}

.banner-card__subtitle {
  max-width: 520rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.banner-card__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.banner-card__action--solid {
  background: linear-gradient(180deg, #fb7185, #f43f5e);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(244, 63, 94, 0.28);
}

.banner-swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  margin: 0 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
}

.banner-swiper .wx-swiper-dot-active {
  width: 36rpx;
  background: #ffffff;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.section-head__more {
  font-size: 20rpx;
  color: #999999;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx 12rpx;
}

.category-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.category-tile__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8a4b3a;
}

.category-tile__icon--0 {
  background: #ffe9e2;
}

.category-tile__icon--1 {
  background: #fff1d8;
}

.category-tile__icon--2 {
  background: #e7f3ff;
}

.category-tile__icon--3 {
  background: #eaf7ec;
}

.category-tile__name {
  font-size: 22rpx;
  font-weight: 500;
  color: #333333;
  text-align: center;
}

.category-tile__tagline {
  font-size: 18rpx;
  color: #999999;
  text-align: center;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
