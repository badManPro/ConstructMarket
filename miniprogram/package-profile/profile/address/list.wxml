<view class="screen address-list-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon" bindtap="handleGoBack">←</view>
      <view class="page-head__title">收货地址</view>
      <view class="page-head__icon"></view>
    </view>
    <view class="page-head__sub">
      {{scene === 'checkout' ? '请选择用于当前订单的收货地址。' : '管理默认地址和项目收货信息。'}}
    </view>
  </view>

  <view wx:if="{{!addresses.length}}" class="section-card empty-card">
    <view class="empty-card__title">还没有收货地址</view>
    <view class="empty-card__desc">先新增项目部、工地或仓库地址，后续可在结算页直接回流选择。</view>
    <view class="empty-card__action" bindtap="handleAdd">新增地址</view>
  </view>

  <block wx:else>
    <view
      wx:for="{{addresses}}"
      wx:key="id"
      class="section-card address-card {{selectedAddressId === item.id ? 'address-card--selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="handleAddressTap"
    >
      <view class="address-card__head">
        <view class="address-card__user">{{item.receiver}} {{item.phone}}</view>
        <view wx:if="{{item.isDefault}}" class="address-card__badge">默认</view>
      </view>
      <view class="address-card__tag">{{item.tag}}</view>
      <view class="address-card__address">{{item.province}} {{item.city}} {{item.district}} {{item.detail}}</view>
      <view wx:if="{{scene === 'checkout' && selectedAddressId === item.id}}" class="address-card__selected">当前用于结算</view>

      <view class="address-card__actions">
        <view class="address-card__action address-card__action--ghost" data-id="{{item.id}}" catchtap="handleSetDefault">
          {{item.isDefault ? '默认地址' : '设为默认'}}
        </view>
        <view class="address-card__action address-card__action--ghost" data-id="{{item.id}}" catchtap="handleEdit">编辑</view>
        <view class="address-card__action address-card__action--danger" data-id="{{item.id}}" catchtap="handleDelete">删除</view>
      </view>
    </view>
  </block>

  <view class="address-toolbar">
    <view class="address-toolbar__button" bindtap="handleAdd">新增地址</view>
  </view>
</view>
