<view class="product-card" bindtap="handleTap">
  <view class="product-card__cover" style="background: {{item.coverTone}};">
    <image class="product-card__cover-image" src="{{item.cover}}" mode="aspectFill"></image>
    <view class="product-card__cover-shade"></view>

    <view class="product-card__cover-tags">
      <view wx:for="{{item.tags}}" wx:key="*this" class="product-card__cover-tag">{{item}}</view>
    </view>

    <view wx:if="{{item.stock && item.stock < 10}}" class="product-card__cover-stock">
      仅剩 {{item.stock}}{{item.unit}}
    </view>

    <view class="product-card__cover-text">
      <view class="product-card__cover-brand">{{item.brand}}</view>
      <view class="product-card__cover-model">{{item.specText || item.model}}</view>
    </view>
  </view>

  <view class="product-card__body">
    <view class="product-card__header">
      <view class="product-card__name">{{item.name}}</view>
      <view
        wx:if="{{showFavorite}}"
        class="product-card__favorite {{item.isFavorite ? 'product-card__favorite--active' : ''}}"
        catchtap="handleFavoriteTap"
      >
        {{item.isFavorite ? '已藏' : '收藏'}}
      </view>
    </view>

    <view class="product-card__meta">{{item.categoryName}} · {{item.brand}}</view>
    <view class="product-card__spec">{{item.specText || item.model}}</view>

    <view class="product-card__info-row">
      <view class="product-card__rating">评分 {{item.rating || '--'}}</view>
      <view class="product-card__stats">销量 {{item.salesVolume}} · 起订 {{item.minOrderQty}}{{item.unit}}</view>
    </view>

    <view class="product-card__footer">
      <view>
        <view class="product-card__price-wrap">
          <view class="product-card__price">¥{{item.price}}</view>
          <view wx:if="{{item.originalPrice}}" class="product-card__origin">¥{{item.originalPrice}}</view>
        </view>
        <view class="product-card__unit">/ {{item.unit}} · {{item.stockStatus}}</view>
      </view>
      <view class="product-card__cta">查看</view>
    </view>
  </view>
</view>
