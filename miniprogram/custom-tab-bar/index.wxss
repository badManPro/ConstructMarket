.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 10rpx 18rpx calc(10rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #ededed;
  box-shadow: 0 -6rpx 16rpx rgba(31, 31, 31, 0.04);
}

.tabbar__item {
  flex: 1;
  padding: 12rpx 0;
  text-align: center;
  color: #888888;
}

.tabbar__item--active {
  color: #ff4a43;
}

.tabbar__text {
  font-size: 22rpx;
  font-weight: 500;
}
