<view class="screen result-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon"></view>
      <view class="page-head__title">支付结果</view>
      <view class="page-head__icon"></view>
    </view>
  </view>

  <view class="result-panel">
    <view class="result-panel__icon {{status === 'success' ? 'result-panel__icon--success' : 'result-panel__icon--failed'}}"></view>
    <view class="result-panel__title {{status === 'success' ? 'result-panel__title--success' : 'result-panel__title--failed'}}">{{title}}</view>
    <view class="result-panel__summary">订单号：{{orderNo}}</view>
    <view class="result-panel__amount">实付金额：¥{{amount}}</view>

    <view class="result-actions">
      <view class="result-actions__ghost" bindtap="handleGoHome">返回首页</view>
      <view wx:if="{{status === 'success'}}" class="result-actions__solid" bindtap="handleGoOrderList">查看订单</view>
      <view wx:else class="result-actions__solid" bindtap="handleBackCheckout">返回结算</view>
    </view>
  </view>
</view>
