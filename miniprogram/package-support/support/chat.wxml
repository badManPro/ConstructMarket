<view class="screen chat-screen">
  <view class="page-head">
    <view class="page-head__bar">
      <view class="page-head__icon" bindtap="handleGoBack">←</view>
      <view class="page-head__title title-with-badge">
        <text>在线咨询</text>
        <text class="developing-badge">开发中</text>
      </view>
      <view class="page-head__icon"></view>
    </view>
    <view class="page-head__sub">{{sessionMeta.subtitle}}</view>
  </view>

  <view wx:if="{{status === 'loading'}}" class="section-card empty-card">
    <view class="empty-card__title">会话加载中</view>
    <view class="empty-card__desc">正在初始化客服欢迎语和快捷问题。</view>
  </view>

  <view wx:elif="{{status === 'error'}}" class="section-card empty-card">
    <view class="empty-card__title">会话读取失败</view>
    <view class="empty-card__desc">请重试本地消息加载，若仍异常可先查看 FAQ。</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleOpenFaq">查看 FAQ</view>
      <view class="empty-card__action" bindtap="handleRetry">重新加载</view>
    </view>
  </view>

  <view wx:elif="{{status === 'offline'}}" class="section-card empty-card">
    <view class="empty-card__title">当前无法发起咨询</view>
    <view class="empty-card__desc">{{sessionMeta.serviceTime}}</view>
    <view class="empty-card__actions">
      <view class="empty-card__action empty-card__action--ghost" bindtap="handleOpenFaq">查看 FAQ</view>
      <view class="empty-card__action" bindtap="handleGoBack">返回上一页</view>
    </view>
  </view>

  <view wx:elif="{{status === 'empty'}}" class="section-card empty-card">
    <view class="empty-card__title">当前还没有会话消息</view>
    <view class="empty-card__desc">你可以直接发送问题，或从下方快捷问题开始。</view>
    <view class="empty-card__action" bindtap="handleRetry">初始化会话</view>
  </view>

  <block wx:else>
    <view class="section-card session-card">
      <view class="session-card__title">{{sessionMeta.title}}</view>
      <view class="session-card__meta">{{sessionMeta.serviceTime}}</view>
      <view class="session-card__desc">{{sessionMeta.responseSla}}</view>
    </view>

    <scroll-view class="chat-scroll" scroll-y scroll-into-view="{{scrollIntoView}}">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message-row {{item.sender === 'user' ? 'message-row--user' : ''}} {{item.sender === 'system' ? 'message-row--system' : ''}}"
      >
        <view class="message-bubble {{item.sender === 'user' ? 'message-bubble--user' : ''}} {{item.sender === 'system' ? 'message-bubble--system' : ''}}">
          <view class="message-bubble__text">{{item.text}}</view>
          <view class="message-bubble__meta">
            <view>{{item.time}}</view>
            <view wx:if="{{item.status === 'failed'}}" class="message-bubble__retry" data-id="{{item.id}}" bindtap="handleResend">重发</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="section-card quick-question-card">
      <view class="section-card__title">快捷问题</view>
      <view class="chip-row">
        <view
          wx:for="{{quickQuestions}}"
          wx:key="id"
          class="route-chip"
          data-text="{{item.text}}"
          bindtap="handleQuickQuestion"
        >
          {{item.text}}
        </view>
      </view>
    </view>

    <view class="chat-toolbar">
      <input
        class="chat-toolbar__input"
        placeholder="输入商品、订单、发票或售后相关问题"
        value="{{draftInput}}"
        bindinput="handleInput"
      />
      <view class="chat-toolbar__button {{pendingReply ? 'chat-toolbar__button--disabled' : ''}}" bindtap="handleSend">
        {{pendingReply ? '回复中' : '发送'}}
      </view>
    </view>
  </block>
</view>
