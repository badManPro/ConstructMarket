.product-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(31, 31, 31, 0.05);
}

.product-card__cover {
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 172rpx;
  min-height: 172rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: #dce2e9;
  color: #444444;
}

.product-card__cover-badge {
  font-size: 20rpx;
  color: #666666;
}

.product-card__cover-brand {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.product-card__cover-model {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.product-card__body {
  flex: 1;
  min-width: 0;
}

.product-card__header {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  align-items: flex-start;
}

.product-card__name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.5;
  color: #222222;
}

.product-card__favorite {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  font-size: 20rpx;
  color: #666666;
}

.product-card__favorite--active {
  background: #fff1f0;
  color: #ff4a43;
}

.product-card__meta {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #888888;
}

.product-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.product-card__tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f7f7f7;
  color: #666666;
  font-size: 20rpx;
}

.product-card__footer {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-end;
  margin-top: 18rpx;
}

.product-card__price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4a43;
}

.product-card__unit {
  font-size: 20rpx;
  color: #888888;
}

.product-card__stats {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.product-card__cta {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1f0;
  color: #ff4a43;
  font-size: 20rpx;
  font-weight: 500;
}
