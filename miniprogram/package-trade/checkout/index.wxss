.checkout-screen {
  padding-bottom: 132rpx;
}

.checkout-source-card {
  margin-top: 12rpx;
}

.checkout-source-card__text {
  font-size: 20rpx;
  color: #666666;
}

.empty-card {
  text-align: center;
}

.empty-card__title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-card__desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.empty-card__actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-card__action {
  display: inline-flex;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.empty-card__action--ghost {
  background: #f4f4f4;
  color: #666666;
}

.trade-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.trade-row__main {
  flex: 1;
}

.trade-row__label {
  font-size: 22rpx;
  color: #666666;
}

.trade-row__value {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.5;
  color: #222222;
}

.trade-row__desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #666666;
}

.trade-row__warn {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #b45309;
}

.trade-row__tag {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f4f4;
  font-size: 20rpx;
  color: #666666;
}

.trade-row__arrow {
  align-self: center;
  color: #999999;
  font-size: 22rpx;
}

.trade-action-row {
  margin-top: 18rpx;
}

.checkout-item {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.checkout-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.checkout-item__cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  background: #dce2e9;
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}

.checkout-item__content {
  flex: 1;
}

.checkout-item__name {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.5;
  color: #222222;
}

.checkout-item__model {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #888888;
}

.checkout-item__meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #ff4a43;
}

.remark-input {
  display: block;
  width: 100%;
  min-height: 120rpx;
  padding: 18rpx;
  border-radius: 10rpx;
  box-sizing: border-box;
  background: #f4f4f4;
  font-size: 22rpx;
  line-height: 1.6;
  color: #222222;
}

.payment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.payment-card {
  padding: 20rpx;
  border: 2rpx solid transparent;
  border-radius: 10rpx;
  background: #f4f4f4;
}

.payment-card--active {
  border-color: #ff4a43;
  background: #fff1f0;
}

.payment-card__title {
  font-size: 24rpx;
  font-weight: 500;
}

.payment-card__desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #666666;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.summary-row__label {
  font-size: 22rpx;
  color: #666666;
}

.summary-row__value {
  font-size: 22rpx;
  color: #222222;
}

.summary-row--strong .summary-row__label,
.summary-row--strong .summary-row__value {
  font-size: 24rpx;
  font-weight: 600;
}

.checkout-toolbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 190rpx;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -6rpx 18rpx rgba(31, 31, 31, 0.06);
}

.checkout-toolbar__summary {
  padding-left: 0;
}

.checkout-toolbar__amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.checkout-toolbar__desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #999999;
}

.checkout-toolbar__submit {
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: #ff4a43;
  color: #ffffff;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
}
