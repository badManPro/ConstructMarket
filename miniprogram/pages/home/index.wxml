<view class="screen home-screen">
  <view class="home-header">
    <view class="home-header__row">
      <view class="home-header__city">{{cityLabel}} ▾</view>
    </view>

    <view class="home-search" bindtap="handleSearchTap">
      <view class="home-search__icon">搜索</view>
      <view class="home-search__text">搜索建材 / 品牌 / 型号</view>
    </view>
  </view>

  <view wx:if="{{status === 'loading'}}" class="section-card home-state-card">
    <view class="section-card__title">首页内容加载中</view>
    <view class="section-card__meta">Banner、分类导航、热销商品和资讯入口正在从服务层刷新。</view>
  </view>

  <view wx:elif="{{status === 'error'}}" class="section-card home-state-card">
    <view class="section-card__title">首页内容读取失败</view>
    <view class="section-card__meta">可以先去选型页继续浏览，或重试当前首页请求。</view>
    <view class="home-state-actions">
      <view class="home-state-actions__ghost" data-route="/pages/category/index" bindtap="handleRouteTap">去选型页</view>
      <view class="home-state-actions__solid" bindtap="handleRetry">重新加载</view>
    </view>
  </view>

  <view wx:elif="{{status === 'offline'}}" class="section-card home-state-card">
    <view class="section-card__title">当前处于离线演示态</view>
    <view class="section-card__meta">恢复网络后可继续加载首页 Banner、分类和商品流。</view>
    <view class="home-state-actions">
      <view class="home-state-actions__ghost" data-route="/pages/category/index" bindtap="handleRouteTap">继续浏览</view>
      <view class="home-state-actions__solid" bindtap="handleRetry">恢复内容</view>
    </view>
  </view>

  <view wx:elif="{{status === 'empty'}}" class="section-card home-state-card">
    <view class="section-card__title">首页暂时没有可展示内容</view>
    <view class="section-card__meta">可以直接进入选型页或搜索结果页继续浏览商品。</view>
    <view class="home-state-actions">
      <view class="home-state-actions__ghost" data-route="/pages/category/index" bindtap="handleRouteTap">去选型页</view>
      <view class="home-state-actions__solid" bindtap="handleSearchTap">去搜索页</view>
    </view>
  </view>

  <block wx:else>
    <view class="home-banner-wrap">
      <swiper class="banner-swiper" indicator-dots circular autoplay interval="4200" duration="360">
        <swiper-item wx:for="{{banners}}" wx:key="id" wx:for-item="banner">
          <view
            class="banner-card {{banner.imageUrl ? 'banner-card--image' : 'banner-card--text'}}"
            style="background: {{banner.accent}};"
            data-route="{{banner.route}}"
            data-params="{{banner.params}}"
            bindtap="handleBannerTap"
          >
            <image wx:if="{{banner.imageUrl}}" class="banner-card__image" src="{{banner.imageUrl}}" mode="aspectFill" />
            <view class="banner-card__scrim"></view>
            <view wx:if="{{!banner.imageUrl}}" class="banner-card__glow"></view>
            <view class="banner-card__content">
              <view class="banner-card__eyebrow">{{banner.eyebrow}}</view>
              <view class="banner-card__title">{{banner.title}}</view>
              <view wx:if="{{banner.subtitle}}" class="banner-card__subtitle">{{banner.subtitle}}</view>
              <view class="banner-card__action banner-card__action--solid">{{banner.actionText}}</view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-card__title">快捷选型</view>
        <view class="section-head__more" data-route="/pages/category/index" bindtap="handleRouteTap">查看更多 ></view>
      </view>
      <view class="category-grid">
        <view
          wx:for="{{categoryNav}}"
          wx:key="id"
          wx:for-index="index"
          class="category-tile"
          data-route="{{item.route}}"
          data-params="{{item.params}}"
          bindtap="handleCategoryTap"
        >
          <view class="category-tile__icon category-tile__icon--{{index}}">{{item.shortName}}</view>
          <view class="category-tile__name">{{item.name}}</view>
          <view class="category-tile__tagline">{{item.tagline}}</view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-card__title">尖货榜单 限时抢</view>
        <view class="section-head__more">查看更多 ></view>
      </view>
      <view class="section-card__meta">优先展示当前工程采购场景里的主推组合。</view>
      <view class="product-list">
        <product-card
          wx:for="{{campaignProducts}}"
          wx:key="id"
          item="{{item}}"
          bindtapcard="handleProductTap"
          bindfavorite="handleFavoriteTap"
        />
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-card__title">热门商品推荐</view>
        <view class="section-head__more">查看更多 ></view>
      </view>
      <view class="section-card__meta">用于验证首页到详情页的主流跳转链路。</view>
      <view class="product-list">
        <product-card
          wx:for="{{hotProducts}}"
          wx:key="id"
          item="{{item}}"
          bindtapcard="handleProductTap"
          bindfavorite="handleFavoriteTap"
        />
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-card__title">建材资讯</view>
        <view class="section-head__more" data-route="/package-content/article/list" bindtap="handleRouteTap">查看更多 ></view>
      </view>
      <view class="link-list">
        <view
          wx:for="{{articleEntrances}}"
          wx:key="id"
          class="link-card"
          data-route="{{item.route}}"
          data-params="{{item.params}}"
          bindtap="handleArticleTap"
        >
          <view class="link-card__title">{{item.category}} · {{item.title}}</view>
          <view class="link-card__desc">{{item.summary}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
